module Test where

import DA.List (head)
import DA.Optional (isSome, isNone, fromSome)
import Daml.Script

import Types
import Holding
import Delegation
import Settlement

-- Visibility helpers. queryContractId returns Some only when `p` is a
-- stakeholder of an active contract, so it is a direct visibility probe.
mustSee : (Template t, HasEnsure t) => Text -> Party -> ContractId t -> Script ()
mustSee label p cid = do
  r <- queryContractId p cid
  assertMsg (label <> ": expected VISIBLE") (isSome r)

mustNotSee : (Template t, HasEnsure t) => Text -> Party -> ContractId t -> Script ()
mustNotSee label p cid = do
  r <- queryContractId p cid
  assertMsg (label <> ": expected NOT visible") (isNone r)

-- Sum a party's balance for one instrument out of a query result.
balOf : [(ContractId Holding, Holding)] -> Text -> Decimal
balOf hs inst = sum [ h.amount | (_, h) <- hs, h.instrument == inst ]

-- ===========================================================================
-- Checkpoint 1: privacy tiers. The centerpiece -- same auction, three views.
-- One contract per tier, then query as each party and assert exactly who can
-- and cannot see it.
-- ===========================================================================
testPrivacyTiers : Script ()
testPrivacyTiers = script do
  owner       <- allocatePartyByHint (PartyIdHint "Owner")
  owner2      <- allocatePartyByHint (PartyIdHint "Owner2")
  exchange    <- allocatePartyByHint (PartyIdHint "Exchange")
  regulator   <- allocatePartyByHint (PartyIdHint "Regulator")
  publicParty <- allocatePartyByHint (PartyIdHint "PublicParty")
  issuer      <- allocatePartyByHint (PartyIdHint "Issuer")

  -- CONFIDENTIAL tier: a Holding (signatory owner, observer issuer).
  holdingCid <- submit owner do
    createCmd Holding with
      issuer; owner; instrument = "wETH"; amount = 10.0

  -- PUBLIC tier: AuctionResult (observer publicParty, regulator).
  now <- getTime
  auctionCid <- submit exchange do
    createCmd AuctionResult with
      exchange; publicParty; regulator
      clearingPrice = 2000.0; totalVolume = 5.0; timestamp = now

  -- REGULATED tier: SettlementRecord (observer regulator, parties).
  recordCid <- submit exchange do
    createCmd SettlementRecord with
      exchange; regulator
      parties = [owner, owner2]
      legs = [ MatchedLeg owner "wETH" (-1.0), MatchedLeg owner2 "wETH" 1.0 ]

  -- PUBLIC tape: public + regulator + exchange; counterparties do not.
  mustSee    "AuctionResult/publicParty"  publicParty auctionCid
  mustSee    "AuctionResult/regulator"    regulator   auctionCid
  mustSee    "AuctionResult/exchange"     exchange    auctionCid
  mustNotSee "AuctionResult/owner"        owner       auctionCid

  -- REGULATED record: regulator + both counterparties + exchange; NOT public.
  mustSee    "SettlementRecord/regulator" regulator   recordCid
  mustSee    "SettlementRecord/owner"     owner       recordCid
  mustSee    "SettlementRecord/owner2"    owner2      recordCid
  mustSee    "SettlementRecord/exchange"  exchange    recordCid
  mustNotSee "SettlementRecord/public"    publicParty recordCid

  -- CONFIDENTIAL holding: owner + issuer only. Not regulator, not public, not
  -- the other counterparty, not even the exchange at rest.
  mustSee    "Holding/owner"     owner       holdingCid
  mustSee    "Holding/issuer"    issuer      holdingCid
  mustNotSee "Holding/owner2"    owner2      holdingCid
  mustNotSee "Holding/regulator" regulator   holdingCid
  mustNotSee "Holding/public"    publicParty holdingCid
  mustNotSee "Holding/exchange"  exchange    holdingCid

  debug "Checkpoint 1: privacy tiers verified -- same auction, three views."
  pure ()

-- ===========================================================================
-- Checkpoint 2: delegation logic. A TradingAuthority gates exactly one
-- instrument up to a ceiling, and revoke ends it. Assert the signatory/observer
-- shape, that over-ceiling and instrument-mismatch fail CLOSED, that a
-- within-ceiling matching debit succeeds, and that Revoke archives it.
-- ===========================================================================
testDelegation : Script ()
testDelegation = script do
  owner    <- allocatePartyByHint (PartyIdHint "Owner")
  exchange <- allocatePartyByHint (PartyIdHint "Exchange")
  issuer   <- allocatePartyByHint (PartyIdHint "Issuer")
  other    <- allocatePartyByHint (PartyIdHint "Other")

  -- owner delegates wETH up to 100 to the exchange.
  authCid <- submit owner do
    createCmd TradingAuthority with
      owner; exchange; instrument = "wETH"; maxAmount = 100.0

  -- owner = signatory; exchange = observer; an unrelated party sees nothing.
  mustSee    "auth/owner(signatory)"   owner    authCid
  mustSee    "auth/exchange(observer)" exchange authCid
  mustNotSee "auth/other"              other    authCid

  -- A matching (wETH) and a mismatching (USDC) holding owned by owner,
  -- disclosed to the exchange for the DebitHolding calls.
  wethCid <- submit owner do
    createCmd Holding with issuer; owner; instrument = "wETH"; amount = 50.0
  usdcCid <- submit owner do
    createCmd Holding with issuer; owner; instrument = "USDC"; amount = 50.0
  wethDisc <- fromSome <$> queryDisclosure owner wethCid
  usdcDisc <- fromSome <$> queryDisclosure owner usdcCid

  -- (1) Over-ceiling: 150 > maxAmount 100 -> fail closed.
  submitMustFail (actAs exchange <> discloseMany [wethDisc]) do
    exerciseCmd authCid DebitHolding with holdingCid = wethCid; amount = 150.0

  -- (2) Instrument mismatch: authority is wETH, holding is USDC -> fail closed.
  submitMustFail (actAs exchange <> discloseMany [usdcDisc]) do
    exerciseCmd authCid DebitHolding with holdingCid = usdcCid; amount = 10.0

  -- (3) Within ceiling + matching instrument -> succeeds (leaves a remainder).
  _ <- submit (actAs exchange <> discloseMany [wethDisc]) do
    exerciseCmd authCid DebitHolding with holdingCid = wethCid; amount = 10.0

  -- (4) Revoke: owner ends the standing authority; archived for everyone.
  submit owner do exerciseCmd authCid Revoke
  mustNotSee "auth/after-revoke(owner)"    owner    authCid
  mustNotSee "auth/after-revoke(exchange)" exchange authCid

  debug "Checkpoint 2: delegation gated; over-limit & mismatch fail closed; revoke works."
  pure ()

-- ===========================================================================
-- Checkpoint 3: settlement logic. A full atomic swap (1 wETH <-> 2000 USDC),
-- then assert balances, then re-assert the privacy tiers on the real emitted
-- data. testSettlementRollback proves a failing leg rolls back ALL legs.
-- ===========================================================================
testSettlement : Script ()
testSettlement = script do
  owner       <- allocatePartyByHint (PartyIdHint "Owner")
  owner2      <- allocatePartyByHint (PartyIdHint "Owner2")
  exchange    <- allocatePartyByHint (PartyIdHint "Exchange")
  regulator   <- allocatePartyByHint (PartyIdHint "Regulator")
  publicParty <- allocatePartyByHint (PartyIdHint "PublicParty")
  issuer      <- allocatePartyByHint (PartyIdHint "Issuer")

  -- Seed holdings ("already onboarded"): owner has 10 wETH, owner2 has 20000 USDC.
  ownerWeth <- submit owner do
    createCmd Holding with issuer; owner; instrument = "wETH"; amount = 10.0
  owner2Usdc <- submit owner2 do
    createCmd Holding with issuer; owner = owner2; instrument = "USDC"; amount = 20000.0

  -- Each party delegates authority for both instruments it touches.
  ownerWethAuth <- submit owner do
    createCmd TradingAuthority with owner; exchange; instrument = "wETH"; maxAmount = 1000000.0
  ownerUsdcAuth <- submit owner do
    createCmd TradingAuthority with owner; exchange; instrument = "USDC"; maxAmount = 1000000.0
  owner2WethAuth <- submit owner2 do
    createCmd TradingAuthority with owner = owner2; exchange; instrument = "wETH"; maxAmount = 1000000.0
  owner2UsdcAuth <- submit owner2 do
    createCmd TradingAuthority with owner = owner2; exchange; instrument = "USDC"; maxAmount = 1000000.0

  -- Matching engine output: swap 1 wETH for 2000 USDC at 2000 USDC/wETH.
  let result = MatchResult with
        legs =
          [ MatchedLeg owner  "wETH" (-1.0)
          , MatchedLeg owner  "USDC" 2000.0
          , MatchedLeg owner2 "wETH" 1.0
          , MatchedLeg owner2 "USDC" (-2000.0)
          ]
        clearingPrice = 2000.0
        totalVolume = 1.0

  reqCid <- submit exchange do
    createCmd SettlementRequest with exchange; publicParty; regulator; result

  -- Givers (delta<0) in leg order: owner's wETH, owner2's USDC. Disclose them.
  ownerWethDisc  <- fromSome <$> queryDisclosure owner  ownerWeth
  owner2UsdcDisc <- fromSome <$> queryDisclosure owner2 owner2Usdc

  submit (actAs exchange <> discloseMany [ownerWethDisc, owner2UsdcDisc]) do
    exerciseCmd reqCid Execute with
      authorities = [ownerWethAuth, ownerUsdcAuth, owner2WethAuth, owner2UsdcAuth]
      holdings    = [ownerWeth, owner2Usdc]

  -- Balances after the atomic swap.
  ownerHoldings  <- query @Holding owner
  owner2Holdings <- query @Holding owner2
  assertMsg "owner wETH == 9"      (balOf ownerHoldings  "wETH" == 9.0)
  assertMsg "owner USDC == 2000"   (balOf ownerHoldings  "USDC" == 2000.0)
  assertMsg "owner2 wETH == 1"     (balOf owner2Holdings "wETH" == 1.0)
  assertMsg "owner2 USDC == 18000" (balOf owner2Holdings "USDC" == 18000.0)

  -- Tiers re-asserted on the real emitted data.
  auctions <- query @AuctionResult publicParty
  let auctionCid = fst (head auctions)
  mustSee    "AuctionResult/public"    publicParty auctionCid
  mustSee    "AuctionResult/regulator" regulator   auctionCid
  mustNotSee "AuctionResult/owner"     owner       auctionCid

  records <- query @SettlementRecord regulator
  let recordCid = fst (head records)
  mustSee    "SettlementRecord/regulator" regulator   recordCid
  mustSee    "SettlementRecord/owner"     owner       recordCid
  mustSee    "SettlementRecord/owner2"    owner2      recordCid
  mustNotSee "SettlementRecord/public"    publicParty recordCid

  -- Confidential positions stay private after settlement: neither the other
  -- counterparty nor the exchange can see owner's new wETH remainder.
  let owWethCid = head [ cid | (cid, h) <- ownerHoldings, h.instrument == "wETH" ]
  mustNotSee "Holding/owner2-cannot-see-owner-wETH"   owner2   owWethCid
  mustNotSee "Holding/exchange-cannot-see-owner-wETH" exchange owWethCid

  debug "Checkpoint 3: atomic swap settled; balances correct; tiers hold on real data."
  pure ()

testSettlementRollback : Script ()
testSettlementRollback = script do
  owner       <- allocatePartyByHint (PartyIdHint "Owner")
  owner2      <- allocatePartyByHint (PartyIdHint "Owner2")
  exchange    <- allocatePartyByHint (PartyIdHint "Exchange")
  regulator   <- allocatePartyByHint (PartyIdHint "Regulator")
  publicParty <- allocatePartyByHint (PartyIdHint "PublicParty")
  issuer      <- allocatePartyByHint (PartyIdHint "Issuer")

  -- Pure check: validateBatch rejects a non-netting batch.
  let badBatch = MatchResult with
        legs = [ MatchedLeg owner "wETH" (-1.0) ]  -- does not net to zero
        clearingPrice = 1.0
        totalVolume = 1.0
  assertMsg "validateBatch rejects non-netting" (validateBatch badBatch == Left LegsDoNotNet)

  ownerWeth <- submit owner do
    createCmd Holding with issuer; owner; instrument = "wETH"; amount = 10.0
  owner2Usdc <- submit owner2 do
    createCmd Holding with issuer; owner = owner2; instrument = "USDC"; amount = 20000.0

  -- owner2's USDC ceiling is too low (1000 < 2000): the USDC give leg fails
  -- closed, so the WHOLE settlement -- including owner's already-debited wETH --
  -- must roll back.
  ownerWethAuth <- submit owner do
    createCmd TradingAuthority with owner; exchange; instrument = "wETH"; maxAmount = 1000000.0
  ownerUsdcAuth <- submit owner do
    createCmd TradingAuthority with owner; exchange; instrument = "USDC"; maxAmount = 1000000.0
  owner2WethAuth <- submit owner2 do
    createCmd TradingAuthority with owner = owner2; exchange; instrument = "wETH"; maxAmount = 1000000.0
  owner2UsdcAuth <- submit owner2 do
    createCmd TradingAuthority with owner = owner2; exchange; instrument = "USDC"; maxAmount = 1000.0

  let result = MatchResult with
        legs =
          [ MatchedLeg owner  "wETH" (-1.0)
          , MatchedLeg owner  "USDC" 2000.0
          , MatchedLeg owner2 "wETH" 1.0
          , MatchedLeg owner2 "USDC" (-2000.0)
          ]
        clearingPrice = 2000.0
        totalVolume = 1.0

  reqCid <- submit exchange do
    createCmd SettlementRequest with exchange; publicParty; regulator; result
  ownerWethDisc  <- fromSome <$> queryDisclosure owner  ownerWeth
  owner2UsdcDisc <- fromSome <$> queryDisclosure owner2 owner2Usdc

  submitMustFail (actAs exchange <> discloseMany [ownerWethDisc, owner2UsdcDisc]) do
    exerciseCmd reqCid Execute with
      authorities = [ownerWethAuth, ownerUsdcAuth, owner2WethAuth, owner2UsdcAuth]
      holdings    = [ownerWeth, owner2Usdc]

  -- Nothing moved: balances are exactly as seeded, and no tiers were emitted.
  ownerHoldings  <- query @Holding owner
  owner2Holdings <- query @Holding owner2
  assertMsg "rollback: owner wETH still 10"     (balOf ownerHoldings  "wETH" == 10.0)
  assertMsg "rollback: owner2 USDC still 20000" (balOf owner2Holdings "USDC" == 20000.0)
  auctions <- query @AuctionResult publicParty
  assertMsg "rollback: no AuctionResult emitted" (null auctions)

  debug "Checkpoint 3: a failing leg rolled back ALL legs; no partial settlement."
  pure ()
