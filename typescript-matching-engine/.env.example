# Auction engine
PORT=3000

# Canton JSON API (your validator node)
CANTON_JSON_API_URL=http://localhost:7575
CANTON_AUTH_TOKEN=

# Settlement contract details — fill in once your teammate deploys the Daml contract
# Get the contract ID by querying the ledger after creation
SETTLEMENT_TEMPLATE_ID=Auction:AuctionSettlement
SETTLEMENT_CONTRACT_ID=
SETTLEMENT_CHOICE=Settle
